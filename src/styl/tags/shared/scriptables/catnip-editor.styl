catnip-editor
    background borderPale
    border-radius br
    border 1px solid borderBright
    box-sizing border-box
    .&-scriptable-aCanvas
        overflow-y scroll
        padding 0 0.5rem 0.5rem
        catnip-block
            margin-bottom 0
            margin-top 0
    &.flexrow > .flexfix
        width 20rem
        flex 0 1 auto
    .&-aTrashZone
        color error
        border 1px solid error
        background background
        text-align center
        padding 0.5rem
        border-bottom-right-radius br
        margin-bottom -0.5px // why?
        margin-right -1px
    catnip-library
        border-top-right-radius br
        border-bottom-right-radius br
