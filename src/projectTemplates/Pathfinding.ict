  - type: folder
    uid: 9BkDjzW7zhzHGm
    colorClass: error
    icon: smiley-happy
    name: Character
    lastmod: 1772361546100
    entries:
      - lastmod: 1772441489649
        type: texture
        name: Character
        untill: 0
        grid:
          - 1
          - 1
        axis:
          - 0
          - 0
        marginx: 0
        marginy: 0
        imgWidth: 64
        imgHeight: 64
        width: 64
        height: 64
        offx: 0
        offy: 0
        origname: iF3b4bRMzkw1qkw.png
        shape: rect
        left: 0
        right: 64
        top: 0
        bottom: 64
        uid: F3b4bRMzkw1qkw
        padding: 1
        isBlank: false
        r: 32
      - uid: WFQm2kKG1nGC3C
        name: Character_OnCellChange
        code:
          - lib: core.misc
            code: note
            values:
              note: >-
                This script is specified in the Character template's behavior
                fields and is applied every character's step on a new cell. Here
                we can check for interactive stuff under/around the hero and
                implement gameplay mechanics like picking items and opening
                doors.

                The behavior applies this script to its copy, meaning that we
                can use properties of the character as if we were writing a
                script for a template. The behavior also provides "x" and "y"
                options with new cell location on a grid.
          - lib: core.misc
            code: group
            values:
              blocks:
                - lib: core.propsVars
                  code: set
                  values:
                    var:
                      lib: core.hidden
                      code: variable
                      values:
                        variableName: pickup
                    value:
                      lib: core.arrays
                      code: get 2d
                      values:
                        obj:
                          lib: core.hidden
                          code: global variable raw
                          values:
                            variableName: interactiveMap
                        x:
                          lib: core.misc
                          code: get function option
                          values:
                            key: x
                        'y':
                          lib: core.misc
                          code: get function option
                          values:
                            key: 'y'
                - lib: core.logic
                  code: if branch
                  values:
                    body1:
                      - lib: core.logic
                        code: if branch
                        values:
                          body1:
                            - lib: core.console
                              code: log
                              values:
                                any: 'Interactive object under the character:'
                            - lib: core.console
                              code: log
                              values:
                                any:
                                  lib: core.hidden
                                  code: variable
                                  values:
                                    variableName: pickup
                          condition:
                            lib: core.hidden
                            code: global variable boolean
                            values:
                              variableName: isDebugOn
                      - lib: core.logic
                        code: if branch
                        values:
                          body1:
                            - lib: core.templates
                              code: kill by ref
                              values:
                                ref:
                                  lib: core.hidden
                                  code: variable
                                  values:
                                    variableName: pickup
                            - lib: core.propsVars
                              code: increment
                              values:
                                var:
                                  lib: core.hidden
                                  code: global variable number
                                  values:
                                    variableName: keys
                          condition:
                            lib: core.templates
                            code: is of template
                            values:
                              copy:
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: pickup
                              template: pKwwNfJRWrJzRH
                      - lib: core.logic
                        code: if branch
                        values:
                          body1:
                            - lib: core.templates
                              code: kill by ref
                              values:
                                ref:
                                  lib: core.hidden
                                  code: variable
                                  values:
                                    variableName: pickup
                            - lib: core.propsVars
                              code: increment
                              values:
                                var:
                                  lib: core.hidden
                                  code: global variable number
                                  values:
                                    variableName: berries
                          condition:
                            lib: core.templates
                            code: is of template
                            values:
                              copy:
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: pickup
                              template: qLhDR3b7hDwC6K
                    condition:
                      lib: core.hidden
                      code: variable
                      values:
                        variableName: pickup
            groupName: Pickups under us
          - lib: core.misc
            code: group
            values:
              blocks:
                - lib: core.misc
                  code: note
                  values:
                    note: >-
                      In this example, we will need to check the adjacent cells
                      for doors. The adjacentCells array is prefilled at game
                      start by the "SetupAdjacentCells" script and contains x;y
                      properties with relative location to check around the
                      player (x:0, y:1, x:1, y:0 and so on)
                - lib: core.logic
                  code: for each
                  values:
                    body:
                      - lib: core.propsVars
                        code: set
                        values:
                          var:
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: checkX
                          value:
                            lib: core.math
                            code: +
                            values:
                              a:
                                lib: core.misc
                                code: get function option
                                values:
                                  key: x
                              b:
                                lib: core.objects
                                code: object read
                                values:
                                  property: x
                                  object:
                                    lib: core.hidden
                                    code: variable
                                    values:
                                      variableName: pair
                      - lib: core.propsVars
                        code: set
                        values:
                          var:
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: checkY
                          value:
                            lib: core.math
                            code: +
                            values:
                              a:
                                lib: core.misc
                                code: get function option
                                values:
                                  key: 'y'
                              b:
                                lib: core.objects
                                code: object read
                                values:
                                  property: 'y'
                                  object:
                                    lib: core.hidden
                                    code: variable
                                    values:
                                      variableName: pair
                      - lib: core.misc
                        code: note
                        values:
                          note: Skip cells out of map bounds
                      - lib: core.logic
                        code: if branch
                        values:
                          body1:
                            - lib: core.logic
                              code: continue loop
                              values: {}
                          condition:
                            lib: core.logic
                            code: a OR b
                            values:
                              a:
                                lib: core.math
                                code: <
                                values:
                                  a:
                                    lib: core.hidden
                                    code: variable
                                    values:
                                      variableName: checkX
                                  b: 0
                              b:
                                lib: core.math
                                code: '>='
                                values:
                                  a:
                                    lib: core.hidden
                                    code: variable
                                    values:
                                      variableName: checkX
                                  b:
                                    lib: core.hidden
                                    code: global variable number
                                    values:
                                      variableName: mapWidth
                      - lib: core.logic
                        code: if branch
                        values:
                          body1:
                            - lib: core.logic
                              code: continue loop
                              values: {}
                          condition:
                            lib: core.logic
                            code: a OR b
                            values:
                              a:
                                lib: core.math
                                code: <
                                values:
                                  b: 0
                                  a:
                                    lib: core.hidden
                                    code: variable
                                    values:
                                      variableName: checkY
                              b:
                                lib: core.math
                                code: '>='
                                values:
                                  a:
                                    lib: core.hidden
                                    code: variable
                                    values:
                                      variableName: checkY
                                  b:
                                    lib: core.hidden
                                    code: global variable number
                                    values:
                                      variableName: mapHeight
                      - lib: core.misc
                        code: note
                        values:
                          note: >-
                            Get the neighbouring copy and interact with valid
                            targets
                      - lib: core.propsVars
                        code: set
                        values:
                          var:
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: copy
                          value:
                            lib: core.arrays
                            code: get 2d
                            values:
                              obj:
                                lib: core.hidden
                                code: global variable raw
                                values:
                                  variableName: interactiveMap
                              x:
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: checkX
                              'y':
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: checkY
                      - lib: core.logic
                        code: if branch
                        values:
                          body1:
                            - lib: core.logic
                              code: if branch
                              values:
                                body1:
                                  - lib: core.propsVars
                                    code: decrement
                                    values:
                                      var:
                                        lib: core.hidden
                                        code: global variable number
                                        values:
                                          variableName: keys
                                  - lib: core.templates
                                    code: kill by ref
                                    values:
                                      ref:
                                        lib: core.hidden
                                        code: variable
                                        values:
                                          variableName: copy
                                condition:
                                  lib: core.logic
                                  code: a AND b
                                  values:
                                    a:
                                      lib: core.templates
                                      code: is of template
                                      values:
                                        template: 1J5D36QdJ24Rmp
                                        copy:
                                          lib: core.hidden
                                          code: variable
                                          values:
                                            variableName: copy
                                    b:
                                      lib: core.math
                                      code: '>'
                                      values:
                                        a:
                                          lib: core.hidden
                                          code: global variable number
                                          values:
                                            variableName: keys
                                        b: 0
                          condition:
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: copy
                    variableName:
                      lib: core.hidden
                      code: variable
                      values:
                        variableName: pair
                    array:
                      lib: core.hidden
                      code: global variable raw
                      values:
                        variableName: adjacentCells
            groupName: Interactive objects around us
        language: catnip
        variables:
          - pickup
          - pair
          - checkX
          - checkY
          - copy
        runAutomatically: false
        lastmod: 1772441495336
        type: script
      - type: template
        baseClass: AnimatedSprite
        name: Character
        depth: 10
        texture: F3b4bRMzkw1qkw
        playAnimationOnStart: false
        loopAnimation: true
        animationFPS: 30
        visible: true
        events:
          - eventKey: signal
            code:
              - lib: core.misc
                code: note
                values:
                  note: >-
                    We will order path calculations for all the berries, and
                    store paths in a temporary array. We will also track how
                    many paths are still calculating in "computingPaths"
                    variable to start calculating the shortest one when all of
                    them are found.

                    As we work in one event, we can use the same variables
                    despite some of the commands being asynchronous.
              - lib: core.arrays
                code: array create
                values:
                  return:
                    lib: core.hidden
                    code: variable
                    values:
                      variableName: validPaths
              - lib: core.propsVars
                code: set
                values:
                  var:
                    lib: core.hidden
                    code: variable
                    values:
                      variableName: computingPaths
                  value:
                    lib: core.arrays
                    code: array length
                    values:
                      array:
                        lib: core
                        code: templates.list
                        values:
                          list: qLhDR3b7hDwC6K
              - lib: core.misc
                code: note
                values:
                  note: >-
                    We will make a small function to avoid duplicating the same
                    blocks when a path was and wasn't found.
              - lib: core.misc
                code: define function
                values:
                  code:
                    - lib: core.propsVars
                      code: decrement
                      values:
                        var:
                          lib: core.hidden
                          code: variable
                          values:
                            variableName: computingPaths
                    - lib: core.logic
                      code: if branch
                      values:
                        body1:
                          - lib: core.logic
                            code: if branch
                            values:
                              body1:
                                - lib: core.console
                                  code: log
                                  values:
                                    any: Finding the best path! Avaliable paths are
                                  disabled: true
                                - lib: core.console
                                  code: log
                                  values:
                                    any:
                                      lib: core.hidden
                                      code: variable
                                      values:
                                        variableName: validPaths
                                  disabled: true
                                - lib: core.script
                                  code: run script
                                  values:
                                    name: WBn9F8gnJNchCn
                                    return:
                                      lib: core.hidden
                                      code: variable
                                      values:
                                        variableName: bestPath
                                  customOptions:
                                    paths:
                                      lib: core.hidden
                                      code: variable
                                      values:
                                        variableName: validPaths
                                - lib: core.console
                                  code: log
                                  values:
                                    any: Best path is
                                  disabled: true
                                - lib: core.console
                                  code: log
                                  values:
                                    any:
                                      lib: core.hidden
                                      code: variable
                                      values:
                                        variableName: bestPath
                                  disabled: true
                                - lib: core.misc
                                  code: execute function
                                  values:
                                    func:
                                      lib: core.hidden
                                      code: behavior property
                                      values:
                                        variableName: startPath
                                  customOptions:
                                    path:
                                      lib: core.hidden
                                      code: variable
                                      values:
                                        variableName: bestPath
                                - lib: core.misc
                                  code: note
                                  values:
                                    note: >-
                                      Clear the array with unneeded paths to
                                      free the memory
                                - lib: core.arrays
                                  code: array clear
                                  values:
                                    array:
                                      lib: core.hidden
                                      code: variable
                                      values:
                                        variableName: validPaths
                              condition:
                                lib: core.logic
                                code: a AND b
                                values:
                                  a:
                                    lib: core.math
                                    code: '>'
                                    values:
                                      a:
                                        lib: core.arrays
                                        code: array length
                                        values:
                                          array:
                                            lib: core.hidden
                                            code: variable
                                            values:
                                              variableName: validPaths
                                      b: 0
                                  b:
                                    lib: core.templates
                                    code: is valid
                                    values:
                                      copy:
                                        lib: core.propsVars
                                        code: this
                                        values: {}
                        condition:
                          lib: core.logic
                          code: is
                          values:
                            a:
                              lib: core.hidden
                              code: variable
                              values:
                                variableName: computingPaths
                            b: 0
                  store:
                    lib: core.hidden
                    code: variable
                    values:
                      variableName: onPathCompute
              - lib: core.misc
                code: note
                values:
                  note: Actual pathfinding goes here.
              - lib: core.logic
                code: for each
                values:
                  body:
                    - lib: pathfinder
                      code: pathfinder findPath coords
                      values:
                        then:
                          - lib: core.arrays
                            code: array push
                            values:
                              array:
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: validPaths
                              elt:
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: path
                          - lib: core.misc
                            code: execute function
                            values:
                              func:
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: onPathCompute
                        catch:
                          - lib: core.misc
                            code: execute function
                            values:
                              func:
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: onPathCompute
                        map:
                          lib: core.hidden
                          code: global variable raw
                          values:
                            variableName: map
                        x:
                          lib: core.movement
                          code: x of
                          values:
                            copy:
                              lib: core.hidden
                              code: variable
                              values:
                                variableName: berry
                        'y':
                          lib: core.movement
                          code: y of
                          values:
                            copy:
                              lib: core.hidden
                              code: variable
                              values:
                                variableName: berry
                        path:
                          lib: core.hidden
                          code: variable
                          values:
                            variableName: path
                  variableName:
                    lib: core.hidden
                    code: variable
                    values:
                      variableName: berry
                  array:
                    lib: core
                    code: templates.list
                    values:
                      list: qLhDR3b7hDwC6K
            arguments:
              signal: Find berry
              once: false
            lib: signals
            variables:
              - validPaths
              - berry
              - computingPaths
              - path
              - onPathCompute
              - bestPath
          - eventKey: signal
            code:
              - lib: core.misc
                code: execute function
                values:
                  func:
                    lib: core.hidden
                    code: behavior property
                    values:
                      variableName: abortPath
                customOptions:
                  adjustPosition:
                    lib: core.logic
                    code: 'true'
                    values: {}
            arguments:
              signal: Abort movement
              once: false
            lib: signals
            variables: []
          - eventKey: signal
            code:
              - lib: core.misc
                code: note
                values:
                  note: >-
                    See the options passed to the functions; We shift the
                    pointer position for half the cell size as the target is not
                    centered but players want a natural, centered placement 
              - lib: core.misc
                code: execute function
                values:
                  func:
                    lib: core.hidden
                    code: behavior property
                    values:
                      variableName: goToPoint
                customOptions:
                  x:
                    lib: core.math
                    code: '-'
                    values:
                      a:
                        lib: pointer
                        code: pointer.x
                        values: {}
                      b:
                        lib: core.hidden
                        code: global variable number
                        values:
                          variableName: halfCellWidth
                  'y':
                    lib: core.math
                    code: '-'
                    values:
                      b:
                        lib: core.hidden
                        code: global variable number
                        values:
                          variableName: halfCellHeight
                      a:
                        lib: pointer
                        code: pointer.y
                        values: {}
            arguments:
              signal: Map click
              once: false
            lib: signals
            variables: []
        extends:
          cgroup: ''
          cellTime: 0.1
          ignoreCost: false
          onCellChanged: WFQm2kKG1nGC3C
          onArrived: -1
        lastmod: 1772441511343
        uid: fg2QgKtzd5qMq8
        behaviors:
          - D2RqLdcMm2P2Fb
        extendTypes: ''
        properties: []
