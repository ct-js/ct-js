  - type: template
    baseClass: AnimatedSprite
    name: Target
    depth: 100
    texture: 5CLm7pH8FQJcWp
    playAnimationOnStart: false
    loopAnimation: true
    animationFPS: 30
    visible: true
    events:
      - eventKey: OnStep
        lib: core
        code:
          - lib: core.misc
            code: note
            values:
              note: >-
                We shift the pointer position for half the cell size as the
                target is not centered but players want a natural, centered
                placement 
          - lib: core.movement
            code: set x
            values:
              pixels:
                lib: core.math
                code: '*'
                values:
                  a:
                    lib: core.math
                    code: round
                    values:
                      a:
                        lib: core.math
                        code: /
                        values:
                          b:
                            lib: core.hidden
                            code: global variable number
                            values:
                              variableName: mapCellWidth
                          a:
                            lib: core.math
                            code: '-'
                            values:
                              a:
                                lib: pointer
                                code: pointer.x
                                values: {}
                              b:
                                lib: core.hidden
                                code: global variable number
                                values:
                                  variableName: halfCellWidth
                  b:
                    lib: core.hidden
                    code: global variable number
                    values:
                      variableName: mapCellWidth
          - lib: core.movement
            code: set y
            values:
              pixels:
                lib: core.math
                code: '*'
                values:
                  a:
                    lib: core.math
                    code: round
                    values:
                      a:
                        lib: core.math
                        code: /
                        values:
                          b:
                            lib: core.hidden
                            code: global variable number
                            values:
                              variableName: mapCellHeight
                          a:
                            lib: core.math
                            code: '-'
                            values:
                              a:
                                lib: pointer
                                code: pointer.y
                                values: {}
                              b:
                                lib: core.hidden
                                code: global variable number
                                values:
                                  variableName: halfCellHeight
                  b:
                    lib: core.hidden
                    code: global variable number
                    values:
                      variableName: mapCellHeight
        arguments: {}
