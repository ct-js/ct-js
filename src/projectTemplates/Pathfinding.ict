                    code: global variable boolean
                    values:
                      variableName: isDebugOn
                  value:
                    lib: core.logic
                    code: NOT a
                    values:
                      a:
                        lib: core.hidden
                        code: global variable boolean
                        values:
                          variableName: isDebugOn
              - lib: core.logic
                code: if else branch
                values:
                  body1:
                    - lib: pathfinder
                      code: pathfinder.drawDebugMap
                      values:
                        return:
                          lib: core.hidden
                          code: global variable raw
                          values:
                            variableName: debugGraphic
                        map:
                          lib: core.hidden
                          code: global variable raw
                          values:
                            variableName: map
                  body2:
                    - lib: pathfinder
                      code: pathfinder.removeAllDebugGraphics
                      values: {}
                  condition:
                    lib: core.hidden
                    code: global variable boolean
                    values:
                      variableName: isDebugOn
            arguments: {}
            lib: core
            variables: []
