              - lib: core.misc
                code: note
                values:
                  note: >-
                    Half-side variables help keep code a bit cleaner when
                    shifting the grid for better pointer positioning
              - lib: core.propsVars
                code: set
                values:
                  var:
                    lib: core.hidden
                    code: global variable number
                    values:
                      variableName: halfCellWidth
                  value:
                    lib: core.math
                    code: /
                    values:
                      a:
                        lib: core.hidden
                        code: global variable number
                        values:
                          variableName: mapCellWidth
                      b: 2
              - lib: core.propsVars
                code: set
                values:
                  var:
                    lib: core.hidden
                    code: global variable number
                    values:
                      variableName: halfCellHeight
                  value:
                    lib: core.math
                    code: /
                    values:
                      a:
                        lib: core.hidden
                        code: global variable number
                        values:
                          variableName: mapCellHeight
                      b: 2
              - lib: core.misc
                code: note
                values:
                  note: >-
                    Obstacles and interactive 1D arrays are for preplaced
                    copies; 2D interactive map is used for gameplay mechanics
                    like opening doors and collecting keysd
              - lib: core.misc
                code: group
                values:
                  blocks:
                    - lib: core.propsVars
                      code: set
                      values:
                        var:
                          lib: core.hidden
                          code: global variable number
                          values:
                            variableName: mapWidth
                        value:
                          lib: core.math
                          code: round
                          values:
                            a:
                              lib: core.math
                              code: /
                              values:
                                a:
                                  lib: core.camera
                                  code: get width
                                  values: {}
                                b:
                                  lib: core.hidden
                                  code: global variable number
                                  values:
                                    variableName: mapCellWidth
                    - lib: core.propsVars
                      code: set
                      values:
                        var:
                          lib: core.hidden
                          code: global variable number
                          values:
                            variableName: mapHeight
                        value:
                          lib: core.math
                          code: round
                          values:
                            a:
                              lib: core.math
                              code: /
                              values:
                                a:
                                  lib: core.camera
                                  code: get height
                                  values: {}
                                b:
                                  lib: core.hidden
                                  code: global variable number
                                  values:
                                    variableName: mapCellHeight
                    - lib: core.arrays
                      code: array create 2d
                      values:
                        return:
                          lib: core.hidden
                          code: global variable raw
                          values:
                            variableName: interactiveMap
                        columns:
                          lib: core.hidden
                          code: global variable number
                          values:
                            variableName: mapWidth
                        rows:
                          lib: core.hidden
                          code: global variable number
                          values:
                            variableName: mapHeight
                    - lib: core.misc
                      code: note
                      values:
                        note: Create a pathfinder map covering the whole vierwport
                    - lib: pathfinder
                      code: pathfinder.create
                      values:
                        diagonals:
                          lib: core.logic
                          code: 'true'
                          values: {}
                        cornerCutting:
                          lib: core.logic
                          code: 'false'
                          values: {}
                        return:
                          lib: core.hidden
                          code: global variable raw
                          values:
                            variableName: map
                    - lib: core.misc
                      code: note
                      values:
                        note: >-
                          Define which cells are walkable and how difficult they
                          are for traversal (higher is harder) and create a map
                          based on collisions with the room entities:

                          0 — solid (not walkable)

                          1 — regular tiles

                          2 — puddles, hard to traverse
                    - lib: pathfinder
                      code: pathfinder setCosts
                      values:
                        map:
                          lib: core.hidden
                          code: global variable raw
                          values:
                            variableName: map
                      customOptions:
                        '1': '1'
                        '2': '3'
                    - lib: core.misc
                      code: note
                      values:
                        note: >-
                          This template affords two approaches to making maps:
                          from a pre-existing room design and procedurally
                          generated — here we pick the needed one.

                          In your game, you can pick just one, or make advanced
                          ways to map making like importing it from an external
                          tool.
                    - lib: core.logic
                      code: if else branch
                      values:
                        body1:
                          - lib: core.script
                            code: run script
                            values:
                              name: P6z92pkgp8NMGz
                            customOptions: {}
                        body2:
                          - lib: core.script
                            code: run script
                            values:
                              name: MH6QWFpDcKQRpg
                            customOptions: {}
                        condition:
                          lib: core.hidden
                          code: behavior property
                          values:
                            variableName: generateFromRoom
                    - lib: core.misc
                      code: note
                      values:
                        note: >-
                          Store the generated grid for later use in a short
                          variable (will be used for UI feedback and retrieval
                          of tile costs)
                    - lib: core.propsVars
                      code: set
                      values:
                        var:
                          lib: core.hidden
                          code: global variable raw
                          values:
                            variableName: grid
                        value:
                          lib: pathfinder
                          code: pathfinder.getGrid
                          values:
                            map:
                              lib: core.hidden
                              code: global variable raw
                              values:
                                variableName: map
                groupName: Pathfinding map setup
                groupClosed: false
              - lib: core.misc
                code: group
                values:
                  blocks:
                    - lib: core.misc
                      code: note
                      values:
                        note: >-
                          Obstacles and interactive 1D arrays are for preplaced
                          copies; 2D interactive map is used for gameplay
                          mechanics like opening doors and collecting keys to
                          understand what is under and around a hero.

                          Copies that have corresponding behaviors and that were
                          added in a room through a room editor will have their
                          Creation event run before this room's Start event,
                          thus they add themselves to these 1D arrays so the
                          room can process them after map initialization with
                          the loops below.
                    - lib: core.logic
                      code: for each
                      values:
                        body:
                          - lib: core.propsVars
                            code: set
                            values:
                              value:
                                lib: core.math
                                code: round
                                values:
                                  a:
                                    lib: core.math
                                    code: /
                                    values:
                                      b:
                                        lib: core.hidden
                                        code: global variable number
                                        values:
                                          variableName: mapCellWidth
                                      a:
                                        lib: core.movement
                                        code: x of
                                        values:
                                          copy:
                                            lib: core.hidden
                                            code: variable
                                            values:
                                              variableName: copy
                              var:
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: column
                          - lib: core.propsVars
                            code: set
                            values:
                              value:
                                lib: core.math
                                code: round
                                values:
                                  a:
                                    lib: core.math
                                    code: /
                                    values:
                                      b:
                                        lib: core.hidden
                                        code: global variable number
                                        values:
                                          variableName: mapCellHeight
                                      a:
                                        lib: core.movement
                                        code: y of
                                        values:
                                          copy:
                                            lib: core.hidden
                                            code: variable
                                            values:
                                              variableName: copy
                              var:
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: row
                          - lib: pathfinder
                            code: pathfinder avoidCell
                            values:
                              map:
                                lib: core.hidden
                                code: global variable raw
                                values:
                                  variableName: map
                              column:
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: column
                              row:
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: row
                        variableName:
                          lib: core.hidden
                          code: variable
                          values:
                            variableName: copy
                        array:
                          lib: core.hidden
                          code: global variable raw
                          values:
                            variableName: obstacles
                    - lib: core.logic
                      code: for each
                      values:
                        body:
                          - lib: core.propsVars
                            code: set
                            values:
                              var:
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: column
                              value:
                                lib: core.math
                                code: round
                                values:
                                  a:
                                    lib: core.math
                                    code: /
                                    values:
                                      b:
                                        lib: core.hidden
                                        code: global variable number
                                        values:
                                          variableName: mapCellWidth
                                      a:
                                        lib: core.movement
                                        code: x of
                                        values:
                                          copy:
                                            lib: core.hidden
                                            code: variable
                                            values:
                                              variableName: copy
                          - lib: core.propsVars
                            code: set
                            values:
                              var:
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: row
                              value:
                                lib: core.math
                                code: round
                                values:
                                  a:
                                    lib: core.math
                                    code: /
                                    values:
                                      b:
                                        lib: core.hidden
                                        code: global variable number
                                        values:
                                          variableName: mapCellHeight
                                      a:
                                        lib: core.movement
                                        code: y of
                                        values:
                                          copy:
                                            lib: core.hidden
                                            code: variable
                                            values:
                                              variableName: copy
                          - lib: core.arrays
                            code: array 2d set element
                            values:
                              array:
                                lib: core.hidden
                                code: global variable raw
                                values:
                                  variableName: interactiveMap
                              column:
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: column
                              row:
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: row
                              value:
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: copy
                        variableName:
                          lib: core.hidden
                          code: variable
                          values:
                            variableName: copy
                        array:
                          lib: core.hidden
                          code: global variable raw
                          values:
                            variableName: interactive
                    - lib: core.misc
                      code: note
                      values:
                        note: >-
                          Clear the arrays of copies; not doing so makes them
                          still being referenced and thus remaining in memory
                          while the room goes, even if the copies were killed.
                    - lib: core.arrays
                      code: array clear
                      values:
                        array:
                          lib: core.hidden
                          code: global variable raw
                          values:
                            variableName: obstacles
                    - lib: core.arrays
                      code: array clear
                      values:
                        array:
                          lib: core.hidden
                          code: global variable raw
                          values:
                            variableName: interactive
                groupName: Add pre-placed obstacles and interactive objects
                groupClosed: false
              - lib: core.misc
                code: group
                values:
                  blocks:
                    - lib: core
                      code: rooms.append
                      values:
                        isUi:
                          lib: core.logic
                          code: 'true'
                          values: {}
                        name: prmcRmNChrmJQm
                    - lib: core
                      code: templates.copyIntoRoom
                      values:
                        room:
                          lib: core.propsVars
                          code: this
                          values: {}
                        x: 0
                        'y': 0
                        template: bp9FhRjfDzRWNk
                groupName: UI
                groupClosed: true
            arguments: {}
            lib: core
            variables:
              - copy
              - column
              - row
          - eventKey: OnStep
            code:
              - lib: pathfinder
                code: pathfinder calculate
                values:
                  map:
                    lib: core.hidden
                    code: global variable raw
                    values:
                      variableName: map
            arguments: {}
            lib: core
            variables: []
          - eventKey: OnPointerClick
            code:
              - lib: signals
                code: signals.emit
                values:
                  event: Map click
            arguments: {}
            lib: core
            variables: []
        specification:
          - structure: atomic
            type: checkbox
            mappedType: number
            name: generateFromRoom
            readableName: Generate the navigation grid from the room
            required: false
            fixedLength: 0
        extendTypes: ''
        lastmod: 1772438045849
        uid: 6mnPwwz71KqNNK
        properties: []
      - uid: P6z92pkgp8NMGz
        name: CreateMapFromRoom
        code:
          - lib: pathfinder
            code: pathfinder generateAdvanced
            values:
              map:
                lib: core.hidden
                code: global variable raw
                values:
                  variableName: map
              cellWidth:
                lib: core.hidden
                code: global variable number
                values:
                  variableName: mapCellWidth
              cellHeight:
                lib: core.hidden
                code: global variable number
                values:
                  variableName: mapCellHeight
              startingX: 0
              startingY: 0
              walkable: 0
              fast:
                lib: core.logic
                code: 'true'
                values: {}
              columns:
                lib: core.hidden
                code: global variable number
                values:
                  variableName: mapWidth
              rows:
                lib: core.hidden
                code: global variable number
                values:
                  variableName: mapHeight
              freeCells: 1
            customOptions:
              Solid: '0'
              Slowing: '2'
        language: catnip
        variables: []
        runAutomatically: false
        lastmod: 1772361065755
        type: script
      - uid: MH6QWFpDcKQRpg
        name: CreateMapFromNoise
        code:
          - lib: noise
            code: noise.setSeed
            values:
              val:
                lib: random
                code: random
                values:
                  x: 1
          - lib: core.propsVars
            code: set
            values:
              var:
                lib: core.hidden
                code: variable
                values:
                  variableName: noiseScale
              value: 0.25
          - lib: core.propsVars
            code: set
            values:
              var:
                lib: core.hidden
                code: variable
                values:
                  variableName: hero
              value:
                lib: core.arrays
                code: get
                values:
                  index: 0
                  obj:
                    lib: core
                    code: templates.list
                    values:
                      list: fg2QgKtzd5qMq8
          - lib: core.misc
            code: note
            values:
              note: >-
                A most frequent approach for pathfinding in procedurally
                generated games is making the pathfinding map along with the
                level itself. In this case, you create a 2D array and pass it to
                the pathfinding map. The actual level-generating algorithm
                varies from one game to another; here we use a noise function as
                the most terse approach.
          - lib: core
            code: tilemaps.create
            values:
              return:
                lib: core.hidden
                code: variable
                values:
                  variableName: tilemap
              depth: 0
          - lib: core.arrays
            code: array create 2d
            values:
              columns:
                lib: core.hidden
                code: global variable number
                values:
                  variableName: mapWidth
              rows:
                lib: core.hidden
                code: global variable number
                values:
                  variableName: mapHeight
              return:
                lib: core.hidden
                code: global variable raw
                values:
                  variableName: grid
          - lib: core.misc
            code: note
            values:
              note: >-
                For each cell, sample a noise value based on the position of the
                noise in a room. If it passes a threshold and the tile is not
                too close to a hero character, a tile will be created there.
          - lib: core.logic
            code: for each 2d
            values:
              body:
                - lib: core.propsVars
                  code: set
                  values:
                    value:
                      lib: noise
                      code: noise.perlin2d
                      values:
                        x:
                          lib: core.math
                          code: '*'
                          values:
                            b:
                              lib: core.hidden
                              code: variable
                              values:
                                variableName: noiseScale
                            a:
                              lib: core.hidden
                              code: variable
                              values:
                                variableName: gridX
                        'y':
                          lib: core.math
                          code: '*'
                          values:
                            b:
                              lib: core.hidden
                              code: variable
                              values:
                                variableName: noiseScale
                            a:
                              lib: core.hidden
                              code: variable
                              values:
                                variableName: gridY
                    var:
                      lib: core.hidden
                      code: variable
                      values:
                        variableName: noiseValue
                - lib: core.propsVars
                  code: set
                  values:
                    var:
                      lib: core.hidden
                      code: variable
                      values:
                        variableName: gameX
                    value:
                      lib: core.math
                      code: '*'
                      values:
                        a:
                          lib: core.hidden
                          code: variable
                          values:
                            variableName: gridX
                        b:
                          lib: core.hidden
                          code: global variable number
                          values:
                            variableName: mapCellWidth
                - lib: core.propsVars
                  code: set
                  values:
                    var:
                      lib: core.hidden
                      code: variable
                      values:
                        variableName: gameY
                    value:
                      lib: core.math
                      code: '*'
                      values:
                        a:
                          lib: core.hidden
                          code: variable
                          values:
                            variableName: gridY
                        b:
                          lib: core.hidden
                          code: global variable number
                          values:
                            variableName: mapCellHeight
                - lib: core.propsVars
                  code: set
                  values:
                    var:
                      lib: core.hidden
                      code: variable
                      values:
                        variableName: distanceFromHero
                    value:
                      lib: core
                      code: u.pdc
                      values:
                        x2:
                          lib: core.movement
                          code: x of
                          values:
                            copy:
                              lib: core.hidden
                              code: variable
                              values:
                                variableName: hero
                        y2:
                          lib: core.movement
                          code: y of
                          values:
                            copy:
                              lib: core.hidden
                              code: variable
                              values:
                                variableName: hero
                        x1:
                          lib: core.hidden
                          code: variable
                          values:
                            variableName: gameX
                        y1:
                          lib: core.hidden
                          code: variable
                          values:
                            variableName: gameY
                - lib: core.logic
                  code: if else branch
                  values:
                    body1:
                      - lib: core
                        code: tilemaps.addTile
                        values:
                          tilemap:
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: tilemap
                          textureName: bhtW29HTj6D31F
                          x:
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: gameX
                          'y':
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: gameY
                      - lib: core.misc
                        code: note
                        values:
                          note: 0 is an occupied tile
                      - lib: core.propsVars
                        code: set
                        values:
                          var:
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: tile
                          value: 0
                    condition:
                      lib: core.logic
                      code: a AND b
                      values:
                        a:
                          lib: core.math
                          code: '>'
                          values:
                            a:
                              lib: core.hidden
                              code: variable
                              values:
                                variableName: noiseValue
                            b: 0
                        b:
                          lib: core.math
                          code: '>'
                          values:
                            b: 200
                            a:
                              lib: core.hidden
                              code: variable
                              values:
                                variableName: distanceFromHero
                    body2:
                      - lib: core.misc
                        code: note
                        values:
                          note: 1 is a free tile
                      - lib: core.propsVars
                        code: set
                        values:
                          var:
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: tile
                          value: 1
                      - lib: core.misc
                        code: note
                        values:
                          note: Example of interactive entity spawn
                      - lib: core.logic
                        code: if branch
                        values:
                          body1:
                            - lib: core
                              code: templates.copy
                              values:
                                template: qLhDR3b7hDwC6K
                                x:
                                  lib: core.hidden
                                  code: variable
                                  values:
                                    variableName: gameX
                                'y':
                                  lib: core.hidden
                                  code: variable
                                  values:
                                    variableName: gameY
                          condition:
                            lib: random
                            code: random.chance
                            values:
                              x: 1
                              'y': 100
                - lib: core.arrays
                  code: array 2d set element
                  values:
                    array:
                      lib: core.hidden
                      code: global variable raw
                      values:
                        variableName: grid
                    column:
                      lib: core.hidden
                      code: variable
                      values:
                        variableName: gridX
                    row:
                      lib: core.hidden
                      code: variable
                      values:
                        variableName: gridY
                    value:
                      lib: core.hidden
                      code: variable
                      values:
                        variableName: tile
              x:
                lib: core.hidden
                code: variable
                values:
                  variableName: gridX
              'y':
                lib: core.hidden
                code: variable
                values:
                  variableName: gridY
              array:
                lib: core.hidden
                code: global variable raw
                values:
                  variableName: grid
          - lib: core.misc
            code: note
            values:
              note: >-
                While you can just use a "Set grid block" for pathfinding,
                debugging methods and blocks like "Find a path to coordinate"
                need to know how the pathfinding map translates to the game
                world. When we create a map from a pre-designed room, we set
                dimensions directly in the Fill blocks. But for this case, we
                set the missing parameters here.
          - lib: pathfinder
            code: pathfinder.setProps
            values:
              map:
                lib: core.hidden
                code: global variable raw
                values:
                  variableName: map
              grid:
                lib: core.hidden
                code: global variable raw
                values:
                  variableName: grid
              width:
                lib: core.hidden
                code: global variable number
                values:
                  variableName: mapWidth
              height:
                lib: core.hidden
                code: global variable number
                values:
                  variableName: mapHeight
              startingX: 0
              startingY: 0
              cellWidth:
                lib: core.hidden
                code: global variable number
                values:
                  variableName: mapCellWidth
              cellHeight:
                lib: core.hidden
                code: global variable number
                values:
                  variableName: mapCellHeight
        language: catnip
        variables:
          - gridX
          - gridY
          - tile
          - noiseValue
          - noiseScale
          - hero
          - distanceFromHero
          - tilemap
          - gameX
          - gameY
        runAutomatically: false
        lastmod: 1772359594463
        type: script
      - uid: WBn9F8gnJNchCn
        name: FindBestPath
        code:
          - lib: core.propsVars
            code: set
            values:
              var:
                lib: core.hidden
                code: variable
                values:
                  variableName: bestDistance
              value:
                lib: core.logic
                code: infinity
                values: {}
          - lib: core.logic
            code: for each
            values:
              body:
                - lib: core.misc
                  code: note
                  values:
                    note: >-
                      Sum distances between all points and update bestDistance,
                      bestPath if we found a shorter one.
                - lib: core.propsVars
                  code: set
                  values:
                    var:
                      lib: core.hidden
                      code: variable
                      values:
                        variableName: sum
                    value: 0
                - lib: core.logic
                  code: repeat
                  values:
                    body:
                      - lib: pathfinder
                        code: pathfinder retrieve cell
                        values:
                          path:
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: path
                          index:
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: index
                          column:
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: fromX
                          row:
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: fromY
                      - lib: pathfinder
                        code: pathfinder retrieve cell
                        values:
                          path:
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: path
                          index:
                            lib: core.math
                            code: +
                            values:
                              a:
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: index
                              b: 1
                          column:
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: toX
                          row:
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: toY
                      - lib: core.script
                        code: run script
                        values:
                          return:
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: cellCost
                          name: QWHzDdbK2ndRmk
                        customOptions:
                          x:
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: toX
                          'y':
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: toY
                      - lib: core.misc
                        code: note
                        values:
                          note: >-
                            We don't need to convert distance in grid cells to
                            distance in the game here as we need relative
                            difference of path lengths, and length is a linear
                            scalar, thus we're not using mapCellWidth or
                            mapCellHeight here.

                            If you need path length in pixels, you can reuse
                            this script with more complex calculations, and in
                            cases with square cells, you can multiply the length
                            on a grid with cell side length to get the length of
                            the path in the game world.
                      - lib: core.logic
                        code: if else branch
                        values:
                          body1:
                            - lib: core.propsVars
                              code: increase
                              values:
                                var:
                                  lib: core.hidden
                                  code: variable
                                  values:
                                    variableName: sum
                                val:
                                  lib: core.hidden
                                  code: variable
                                  values:
                                    variableName: cellCost
                          body2:
                            - lib: core.propsVars
                              code: increase
                              values:
                                var:
                                  lib: core.hidden
                                  code: variable
                                  values:
                                    variableName: sum
                                val:
                                  lib: core.math
                                  code: '*'
                                  values:
                                    b:
                                      lib: core.hidden
                                      code: variable
                                      values:
                                        variableName: cellCost
                                    a:
                                      lib: core
                                      code: u.pdc
                                      values:
                                        x1:
                                          lib: core.hidden
                                          code: variable
                                          values:
                                            variableName: fromX
                                        y1:
                                          lib: core.hidden
                                          code: variable
                                          values:
                                            variableName: fromY
                                        x2:
                                          lib: core.hidden
                                          code: variable
                                          values:
                                            variableName: toX
                                        y2:
                                          lib: core.hidden
                                          code: variable
                                          values:
                                            variableName: toY
                          condition:
                            lib: core.hidden
                            code: global variable boolean
                            values:
                              variableName: useFairMovement
                    'N':
                      lib: core.math
                      code: '-'
                      values:
                        a:
                          lib: core.arrays
                          code: array length
                          values:
                            array:
                              lib: core.hidden
                              code: variable
                              values:
                                variableName: path
                        b: 2
                    variableName:
                      lib: core.hidden
                      code: variable
                      values:
                        variableName: index
                - lib: core.logic
                  code: if branch
                  values:
                    body1:
                      - lib: core.propsVars
                        code: set
                        values:
                          var:
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: bestDistance
                          value:
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: sum
                      - lib: core.propsVars
                        code: set
                        values:
                          var:
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: bestPath
                          value:
                            lib: core.hidden
                            code: variable
                            values:
                              variableName: path
                    condition:
                      lib: core.math
                      code: <
                      values:
                        a:
                          lib: core.hidden
                          code: variable
                          values:
                            variableName: sum
                        b:
                          lib: core.hidden
                          code: variable
                          values:
                            variableName: bestDistance
              variableName:
                lib: core.hidden
                code: variable
                values:
                  variableName: path
              array:
                lib: core.objects
                code: object read
                values:
                  property: paths
                  object:
                    lib: core.hidden
                    code: script options
                    values: {}
          - lib: core.misc
            code: return
            values:
              return:
                lib: core.hidden
                code: variable
                values:
                  variableName: bestPath
        language: catnip
        variables:
          - path
          - bestDistance
          - index
          - bestPath
          - sum
          - cellCost
          - fromX
          - fromY
          - toX
          - toY
        runAutomatically: false
        lastmod: 1772441482757
        type: script
      - uid: QWHzDdbK2ndRmk
        name: GetTileCost
        code:
          - lib: core.propsVars
            code: set
            values:
              value:
                lib: core.arrays
                code: get 2d
                values:
                  obj:
                    lib: core.hidden
                    code: global variable raw
                    values:
                      variableName: grid
                  x:
                    lib: core.objects
                    code: object read
                    values:
                      object:
                        lib: core.hidden
                        code: script options
                        values: {}
                      property: x
                  'y':
                    lib: core.objects
                    code: object read
                    values:
                      object:
                        lib: core.hidden
                        code: script options
                        values: {}
                      property: 'y'
              var:
                lib: core.hidden
                code: variable
                values:
                  variableName: cellValue
          - lib: core.misc
            code: note
            values:
              note: >-
                These should match the tile costs declared in the PathfindingMap
                behavior.
          - lib: core.misc
            code: note
            values:
              note: >-
                In the example, tile 2 is puddles, which triples the movement
                cost.
          - lib: core.logic
            code: if branch
            values:
              body1:
                - lib: core.misc
                  code: return
                  values:
                    return: 3
              condition:
                lib: core.logic
                code: is
                values:
                  b: 2
                  a:
                    lib: core.hidden
                    code: variable
                    values:
                      variableName: cellValue
          - lib: core.misc
            code: note
            values:
              note: Default to 1 (assume regular terrain)
          - lib: core.misc
            code: return
            values:
              return: 1
        language: catnip
        variables:
          - col
          - row
          - cellValue
        runAutomatically: false
        lastmod: 1772101509407
        type: script
      - type: behavior
        name: PathdindingObstacle
        behaviorType: template
        events:
          - eventKey: OnCreate
            code:
              - lib: core.misc
                code: note
                values:
                  note: >-
                    This behavior is for non-moving obstacles on the map that
                    can be dynamically added or removed, like doors and gates,
                    or destructible walls.
              - lib: core.misc
                code: note
                values:
                  note: >-
                    Copies' Creation events that were placed in a room manually
                    in the room editor run before the rooms' Room start event,
                    so if we ignore a point right away, it will be written to
                    the previous room's map, not the new one. To counter that,
                    we will put all obstacles put in a room in an array that the
                    room will later read.
              - lib: core.logic
                code: if else branch
                values:
                  body1:
                    - lib: core.arrays
                      code: array push
                      values:
                        array:
                          lib: core.hidden
                          code: global variable raw
                          values:
                            variableName: obstacles
                        elt:
                          lib: core.propsVars
                          code: this
                          values: {}
                  body2:
                    - lib: pathfinder
                      code: pathfinder avoidCell
                      values:
                        map:
                          lib: core.hidden
                          code: global variable raw
                          values:
                            variableName: map
                        column:
                          lib: core.math
                          code: /
                          values:
                            b:
                              lib: core.hidden
                              code: global variable number
                              values:
                                variableName: mapCellWidth
                            a:
                              lib: core.movement
                              code: x
                              values: {}
                        row:
                          lib: core.math
                          code: /
                          values:
                            b:
                              lib: core.hidden
                              code: global variable number
                              values:
                                variableName: mapCellHeight
                            a:
                              lib: core.movement
                              code: 'y'
                              values: {}
                  condition:
                    lib: core.templates
                    code: copy placedInRoom
                    values: {}
            arguments: {}
            lib: core
            variables: []
          - eventKey: OnDestroy
            code:
              - lib: pathfinder
                code: pathfinder stopAvoidingCell
                values:
                  map:
                    lib: core.hidden
                    code: global variable raw
                    values:
                      variableName: map
                  column:
                    lib: core.math
                    code: /
                    values:
                      b:
                        lib: core.hidden
                        code: global variable number
                        values:
                          variableName: mapCellWidth
                      a:
                        lib: core.movement
                        code: x
                        values: {}
                  row:
                    lib: core.math
                    code: /
                    values:
                      b:
                        lib: core.hidden
                        code: global variable number
                        values:
                          variableName: mapCellHeight
                      a:
                        lib: core.movement
                        code: 'y'
                        values: {}
            arguments: {}
            lib: core
            variables: []
        specification: []
        extendTypes: ''
        lastmod: 1772293629030
        uid: 714RNW6tgw7LQk
        properties: []
      - type: behavior
        name: PathfindingCharacter
        behaviorType: template
        events:
          - eventKey: OnCreate
            code:
              - lib: core.propsVars
                code: set
                values:
                  var:
                    lib: core.hidden
                    code: property
                    values:
                      variableName: gridX
                  value:
                    lib: core.math
                    code: round
                    values:
                      a:
                        lib: core.math
                        code: /
                        values:
                          b:
                            lib: core.hidden
                            code: global variable number
                            values:
                              variableName: mapCellWidth
                          a:
                            lib: core.movement
                            code: x
                            values: {}
              - lib: core.propsVars
                code: set
                values:
                  var:
                    lib: core.hidden
                    code: property
                    values:
                      variableName: gridY
                  value:
                    lib: core.math
                    code: round
                    values:
                      a:
                        lib: core.math
                        code: /
                        values:
                          b:
                            lib: core.hidden
                            code: global variable number
                            values:
                              variableName: mapCellHeight
                          a:
                            lib: core.movement
                            code: 'y'
                            values: {}
              - lib: core.misc
                code: note
                values:
                  note: >-
                    These basic functions implement pathfinding and movement
                    along the found path, as well as an additional function to
                    abort current movement. As they are stored as copy's
                    properties, you can call them in templates to make player
                    controllers, or create AI behaviors for mobs.
              - lib: core.misc
                code: note
                values:
                  note: >-
                    goToPoint is a function that executes pathfinding towards a
                    point in the game world, passed in options, and then runs
                    startPath to run the movement. This will usually be the
                    method you use when you know the destination.
              - lib: core.misc
                code: define function
                values:
                  code:
                    - lib: core.misc
                      code: note
                      values:
                        note: 'Cancel an ongoing path calculation, if there is one'
                    - lib: core.logic
                      code: if branch
                      values:
                        body1:
                          - lib: pathfinder
                            code: pathfinder cancelPath
                            values:
                              map:
                                lib: core.hidden
                                code: global variable raw
                                values:
                                  variableName: map
                              id:
                                lib: core.hidden
                                code: property
                                values:
                                  variableName: pathID
                          - lib: core.propsVars
                            code: set
                            values:
                              var:
                                lib: core.hidden
                                code: property
                                values:
                                  variableName: pathID
                              value:
                                lib: core.logic
                                code: 'false'
                                values: {}
                        condition:
                          lib: core.hidden
                          code: property
                          values:
                            variableName: pathID
                    - lib: core.misc
                      code: note
                      values:
                        note: Find a new path
                    - lib: core.propsVars
                      code: set
                      values:
                        var:
                          lib: core.hidden
                          code: variable
                          values:
                            variableName: targetCol
                        value:
                          lib: core.math
                          code: round
                          values:
                            a:
                              lib: core.math
                              code: /
                              values:
                                a:
                                  lib: core.misc
                                  code: get function option
                                  values:
                                    key: x
                                b:
                                  lib: core.hidden
                                  code: global variable number
                                  values:
                                    variableName: mapCellWidth
                    - lib: core.propsVars
                      code: set
                      values:
                        var:
                          lib: core.hidden
                          code: variable
                          values:
                            variableName: targetRow
                        value:
                          lib: core.math
                          code: round
                          values:
                            a:
                              lib: core.math
                              code: /
                              values:
                                a:
                                  lib: core.misc
                                  code: get function option
                                  values:
                                    key: 'y'
                                b:
                                  lib: core.hidden
                                  code: global variable number
                                  values:
                                    variableName: mapCellHeight
                    - lib: core.misc
                      code: note
                      values:
                        note: >-
                          Sometimes we can get invalid coordinates — for
                          example, when a user clicks outside of level's
                          boundaries. Clamp them.
                    - lib: core.propsVars
                      code: set
                      values:
                        var:
                          lib: core.hidden
                          code: variable
                          values:
                            variableName: targetCol
                        value:
                          lib: core
                          code: u.clamp
                          values:
                            min: 0
                            val:
                              lib: core.hidden
                              code: variable
                              values:
                                variableName: targetCol
                            max:
                              lib: core.math
                              code: '-'
                              values:
                                a:
                                  lib: core.hidden
                                  code: global variable number
                                  values:
                                    variableName: mapWidth
                                b: 1
                    - lib: core.propsVars
                      code: set
                      values:
                        var:
                          lib: core.hidden
                          code: variable
                          values:
                            variableName: targetRow
                        value:
                          lib: core
                          code: u.clamp
                          values:
                            min: 0
                            val:
                              lib: core.hidden
                              code: variable
                              values:
                                variableName: targetRow
                            max:
                              lib: core.math
                              code: '-'
                              values:
                                a:
                                  lib: core.hidden
                                  code: global variable number
                                  values:
                                    variableName: mapHeight
                                b: 1
                    - lib: pathfinder
                      code: pathfinder findPath cell from to
                      values:
                        then:
                          - lib: core.propsVars
                            code: set
                            values:
                              var:
                                lib: core.hidden
                                code: property
                                values:
                                  variableName: pathID
                              value:
                                lib: core.logic
                                code: 'false'
                                values: {}
                          - lib: core.misc
                            code: execute function
                            values:
                              func:
                                lib: core.hidden
                                code: property
                                values:
                                  variableName: startPath
                            customOptions:
                              path:
                                lib: core.hidden
                                code: property
                                values:
                                  variableName: path
                          - lib: core.logic
                            code: if branch
                            values:
                              body1:
                                - lib: pathfinder
                                  code: pathfinder.drawDebugPath
                                  values:
                                    path:
                                      lib: core.hidden
                                      code: property
                                      values:
                                        variableName: path
                                    map:
                                      lib: core.hidden
                                      code: global variable raw
                                      values:
                                        variableName: map
                                    return:
                                      lib: core.hidden
                                      code: property
                                      values:
                                        variableName: pathDebug
                              condition:
                                lib: core.hidden
                                code: global variable boolean
                                values:
                                  variableName: isDebugOn
                        catch: []
                        id:
                          lib: core.hidden
                          code: property
                          values:
                            variableName: pathID
                        path:
                          lib: core.hidden
                          code: property
                          values:
                            variableName: path
                        columnFrom:
                          lib: core.hidden
                          code: property
                          values:
                            variableName: gridX
                        rowFrom:
                          lib: core.hidden
                          code: property
                          values:
                            variableName: gridY
                        map:
                          lib: core.hidden
                          code: global variable raw
                          values:
                            variableName: map
                        columnTo:
                          lib: core.hidden
                          code: variable
                          values:
                            variableName: targetCol
                        rowTo:
                          lib: core.hidden
                          code: variable
                          values:
                            variableName: targetRow
                  store:
                    lib: core.hidden
                    code: property
                    values:
                      variableName: goToPoint
              - lib: core.misc
                code: note
                values:
                  note: >-
                    startPath initializes variables to move along a path and
                    runs the stepPath function that does the actual movement.
              - lib: core.misc
                code: define function
                values:
                  code:
                    - lib: core.console
                      code: log
                      values:
                        any: 'Starting a path:'
                      disabled: true
                    - lib: core.console
                      code: log
                      values:
                        any:
                          lib: core.misc
                          code: get function option
                          values:
                            key: path
                      disabled: true
                    - lib: core.logic
                      code: if branch
                      values:
                        body1:
                          - lib: core.misc
                            code: execute function
                            values:
                              func:
                                lib: core.hidden
                                code: property
                                values:
                                  variableName: abortPath
                        condition:
                          lib: core.hidden
                          code: property
                          values:
                            variableName: path
                    - lib: core.propsVars
                      code: set
                      values:
                        var:
                          lib: core.hidden
                          code: property
                          values:
                            variableName: pointIndex
                        value: 0
                    - lib: core.propsVars
                      code: set
                      values:
                        var:
                          lib: core.hidden
                          code: property
                          values:
                            variableName: path
                        value:
                          lib: core.misc
                          code: get function option
                          values:
                            key: path
                    - lib: core.misc
                      code: execute function
                      values:
                        func:
                          lib: core.hidden
                          code: property
                          values:
                            variableName: stepPath
                  store:
                    lib: core.hidden
                    code: property
                    values:
                      variableName: startPath
              - lib: core.misc
                code: note
                values:
                  note: >-
                    Moves a copy to a next point in its path. Calls itself to
                    gradually move along every point in the path.
              - lib: core.misc
                code: define function
                values:
                  code:
                    - lib: core.misc
                      code: note
                      values:
                        note: >-
                          This function will gradually iterate over the current
                          path and move the copy along it by using tweening.
                    - lib: core.misc
                      code: note
                      values:
                        note: >-
                          0th point is always the starting one, so we can skip
                          it and always increment the pointIndex
                    - lib: core.propsVars
                      code: increment
                      values:
                        var:
                          lib: core.hidden
                          code: property
                          values:
                            variableName: pointIndex
                    - lib: core.logic
                      code: if else branch
                      values:
                        body1:
                          - lib: core.misc
                            code: note
                            values:
                              note: >-
                                Get the current point in game coordinates to see
                                where to move the copy, and also in pathfinding
                                grid table to lookup path cost
                          - lib: pathfinder
                            code: pathfinder retrieve cell
                            values:
                              path:
                                lib: core.hidden
                                code: property
                                values:
                                  variableName: path
                              index:
                                lib: core.hidden
                                code: property
                                values:
                                  variableName: pointIndex
                              column:
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: nextX
                              row:
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: nextY
                          - lib: pathfinder
                            code: pathfinder retrieve coordinate
                            values:
                              x:
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: pointX
                              'y':
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: pointY
                              path:
                                lib: core.hidden
                                code: property
                                values:
                                  variableName: path
                              index:
                                lib: core.hidden
                                code: property
                                values:
                                  variableName: pointIndex
                              map:
                                lib: core.hidden
                                code: global variable raw
                                values:
                                  variableName: map
                          - lib: core.logic
                            code: if branch
                            values:
                              body1:
                                - lib: core.script
                                  code: run script
                                  values:
                                    name: QWHzDdbK2ndRmk
                                    return:
                                      lib: core.hidden
                                      code: variable
                                      values:
                                        variableName: movementCost
                                  customOptions:
                                    x:
                                      lib: core.hidden
                                      code: variable
                                      values:
                                        variableName: nextX
                                    'y':
                                      lib: core.hidden
                                      code: variable
                                      values:
                                        variableName: nextY
                                - lib: core.propsVars
                                  code: set
                                  values:
                                    var:
                                      lib: core.hidden
                                      code: variable
                                      values:
                                        variableName: moveDuration
                                    value:
                                      lib: core.math
                                      code: '*'
                                      values:
                                        a:
                                          lib: core.hidden
                                          code: behavior property
                                          values:
                                            variableName: cellTime
                                        b:
                                          lib: core.hidden
                                          code: variable
                                          values:
                                            variableName: movementCost
                              condition:
                                lib: core.logic
                                code: NOT a
                                values:
                                  a:
                                    lib: core.hidden
                                    code: behavior property
                                    values:
                                      variableName: ignoreCost
                          - lib: core.misc
                            code: note
                            values:
                              note: >-
                                Do we need to adjust diagonal movement speed?
                                (You can simplify this in your project to a
                                predetermined behavior)
                          - lib: core.logic
                            code: if branch
                            values:
                              body1:
                                - lib: core.misc
                                  code: note
                                  values:
                                    note: >-
                                      Get the distance between the current and
                                      previous points and calculate movement
                                      duration for the next cell
                                - lib: pathfinder
                                  code: pathfinder retrieve coordinate
                                  values:
                                    path:
                                      lib: core.hidden
                                      code: property
                                      values:
                                        variableName: path
                                    map:
                                      lib: core.hidden
                                      code: global variable raw
                                      values:
                                        variableName: map
                                    index:
                                      lib: core.math
                                      code: '-'
                                      values:
                                        b: 1
                                        a:
                                          lib: core.hidden
                                          code: property
                                          values:
                                            variableName: pointIndex
                                    x:
                                      lib: core.hidden
                                      code: variable
                                      values:
                                        variableName: prevX
                                    'y':
                                      lib: core.hidden
                                      code: variable
                                      values:
                                        variableName: prevY
                                - lib: core.propsVars
                                  code: set
                                  values:
                                    var:
                                      lib: core.hidden
                                      code: variable
                                      values:
                                        variableName: distance
                                    value:
                                      lib: core
                                      code: u.pdc
                                      values:
                                        x1:
                                          lib: core.hidden
                                          code: variable
                                          values:
                                            variableName: prevX
                                        y1:
                                          lib: core.hidden
                                          code: variable
                                          values:
                                            variableName: prevY
                                        x2:
                                          lib: core.hidden
                                          code: variable
                                          values:
                                            variableName: pointX
                                        y2:
                                          lib: core.hidden
                                          code: variable
                                          values:
                                            variableName: pointY
                                - lib: core.propsVars
                                  code: set
                                  values:
                                    var:
                                      lib: core.hidden
                                      code: variable
                                      values:
                                        variableName: moveDuration
                                    value:
                                      lib: core.math
                                      code: '*'
                                      values:
                                        b:
                                          lib: core.hidden
                                          code: variable
                                          values:
                                            variableName: moveDuration
                                        a:
                                          lib: core.math
                                          code: /
                                          values:
                                            a:
                                              lib: core.hidden
                                              code: variable
                                              values:
                                                variableName: distance
                                            b:
                                              lib: core.hidden
                                              code: global variable number
                                              values:
                                                variableName: mapCellWidth
                              body2: []
                              condition:
                                lib: core.hidden
                                code: global variable boolean
                                values:
                                  variableName: useFairMovement
                          - lib: tween
                            code: animate position
                            values:
                              then:
                                - lib: core.propsVars
                                  code: set
                                  values:
                                    var:
                                      lib: core.hidden
                                      code: property
                                      values:
                                        variableName: animation
                                    value:
                                      lib: core.logic
                                      code: 'false'
                                      values: {}
                                - lib: core.propsVars
                                  code: set
                                  values:
                                    var:
                                      lib: core.hidden
                                      code: property
                                      values:
                                        variableName: gridX
                                    value:
                                      lib: core.hidden
                                      code: variable
                                      values:
                                        variableName: nextX
                                - lib: core.propsVars
                                  code: set
                                  values:
                                    var:
                                      lib: core.hidden
                                      code: property
                                      values:
                                        variableName: gridY
                                    value:
                                      lib: core.hidden
                                      code: variable
                                      values:
                                        variableName: nextY
                                - lib: core.logic
                                  code: if branch
                                  values:
                                    body1:
                                      - lib: core.script
                                        code: apply script
                                        values:
                                          name:
                                            lib: core.hidden
                                            code: behavior property
                                            values:
                                              variableName: onCellChanged
                                          target:
                                            lib: core.propsVars
                                            code: this
                                            values: {}
                                        customOptions:
                                          x:
                                            lib: core.hidden
                                            code: property
                                            values:
                                              variableName: gridX
                                          'y':
                                            lib: core.hidden
                                            code: property
                                            values:
                                              variableName: gridY
                                    condition:
                                      lib: core.logic
                                      code: a AND b
                                      values:
                                        a:
                                          lib: core.hidden
                                          code: behavior property
                                          values:
                                            variableName: onCellChanged
                                        b:
                                          lib: core.logic
                                          code: is not
                                          values:
                                            a:
                                              lib: core.hidden
                                              code: behavior property
                                              values:
                                                variableName: onCellChanged
                                            b: -1
                                  disabled: false
                                - lib: core.misc
                                  code: execute function
                                  values:
                                    func:
                                      lib: core.hidden
                                      code: property
                                      values:
                                        variableName: stepPath
                              catch: []
                              target:
                                lib: core.propsVars
                                code: this
                                values: {}
                              ms:
                                lib: core.math
                                code: '*'
                                values:
                                  a:
                                    lib: core.hidden
                                    code: variable
                                    values:
                                      variableName: moveDuration
                                  b: 1000
                              x:
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: pointX
                              'y':
                                lib: core.hidden
                                code: variable
                                values:
                                  variableName: pointY
                              curve:
                                lib: tween
                                code: tween.linear
                                values: {}
                              return:
                                lib: core.hidden
                                code: property
                                values:
                                  variableName: animation
                        condition:
                          lib: core.math
                          code: <
                          values:
                            a:
                              lib: core.hidden
                              code: property
                              values:
                                variableName: pointIndex
                            b:
                              lib: core.arrays
                              code: array length
                              values:
                                array:
                                  lib: core.hidden
                                  code: property
                                  values:
                                    variableName: path
                        body2:
                          - lib: core.misc
                            code: note
                            values:
                              note: >-
                                The path is completed, remove the debug path
                                graphic if it is present
                          - lib: core.logic
                            code: if branch
                            values:
                              body1:
                                - lib: pathfinder
                                  code: pathfinder destroy debug graphic
                                  values:
                                    graphic:
                                      lib: core.hidden
                                      code: property
                                      values:
                                        variableName: pathDebug
                                - lib: core.propsVars
                                  code: set
                                  values:
                                    var:
                                      lib: core.hidden
                                      code: property
                                      values:
                                        variableName: pathDebug
                                    value:
                                      lib: core.logic
                                      code: 'false'
                                      values: {}
                              condition:
                                lib: core.hidden
                                code: property
                                values:
                                  variableName: pathDebug
                          - lib: core.propsVars
                            code: set
                            values:
                              var:
                                lib: core.hidden
                                code: property
                                values:
                                  variableName: animation
                              value:
                                lib: core.logic
                                code: 'false'
                                values: {}
                          - lib: core.logic
                            code: if branch
                            values:
                              body1:
                                - lib: core.script
                                  code: apply script
                                  values:
                                    name:
                                      lib: core.hidden
                                      code: behavior property
                                      values:
                                        variableName: onArrived
                                    target:
                                      lib: core.propsVars
                                      code: this
                                      values: {}
                                  customOptions:
                                    x:
                                      lib: core.hidden
                                      code: property
                                      values:
                                        variableName: gridX
                                    'y':
                                      lib: core.hidden
                                      code: property
                                      values:
                                        variableName: gridY
                              condition:
                                lib: core.logic
                                code: a AND b
                                values:
                                  b:
                                    lib: core.logic
                                    code: is not
                                    values:
                                      b: -1
                                      a:
                                        lib: core.hidden
                                        code: behavior property
                                        values:
                                          variableName: onArrived
                                  a:
                                    lib: core.hidden
                                    code: behavior property
                                    values:
                                      variableName: onArrived
                  store:
                    lib: core.hidden
                    code: property
                    values:
                      variableName: stepPath
              - lib: core.misc
                code: note
                values:
                  note: >-
                    Aborts current movement along a path and resets path-related
                    properties.
              - lib: core.misc
                code: define function
                values:
                  code:
                    - lib: core.console
                      code: log
                      values:
                        any: Aborting current movement
                      disabled: true
                    - lib: core.propsVars
                      code: set
                      values:
                        var:
                          lib: core.hidden
                          code: property
                          values:
                            variableName: path
                        value:
                          lib: core.logic
                          code: 'false'
                          values: {}
                    - lib: core.propsVars
                      code: set
                      values:
                        var:
                          lib: core.hidden
                          code: property
                          values:
                            variableName: pointIndex
                        value: 0
                    - lib: core.logic
                      code: if branch
                      values:
                        body1:
                          - lib: tween
                            code: animation stop
                            values:
                              animation:
                                lib: core.hidden
                                code: property
                                values:
                                  variableName: animation
                          - lib: core.propsVars
                            code: set
                            values:
                              var:
                                lib: core.hidden
                                code: property
                                values:
                                  variableName: animation
                              value:
                                lib: core.logic
                                code: 'false'
                                values: {}
                        condition:
                          lib: core.hidden
                          code: property
                          values:
                            variableName: animation
                    - lib: core.logic
                      code: if branch
                      values:
                        body1:
                          - lib: pathfinder
                            code: pathfinder destroy debug graphic
                            values:
                              graphic:
                                lib: core.hidden
                                code: property
                                values:
                                  variableName: pathDebug
                          - lib: core.propsVars
                            code: set
                            values:
                              var:
                                lib: core.hidden
                                code: property
                                values:
                                  variableName: pathDebug
                              value:
                                lib: core.logic
                                code: 'false'
                                values: {}
                        condition:
                          lib: core.hidden
                          code: property
                          values:
                            variableName: pathDebug
                    - lib: core.misc
                      code: note
                      values:
                        note: >-
                          Sometimes we may want to interrupt movement mid-cell;
                          if you pass an "adjustPosition" option set to true,
                          abortPath will smoothly bring the copy back to its
                          last location.
                    - lib: core.logic
                      code: if branch
                      values:
                        body1:
                          - lib: core.misc
                            code: note
                            values:
                              note: >-
                                Check if we're really off-grid. (Compare the
                                remainder of division with cell size with 0)
                          - lib: core.logic
                            code: if branch
                            values:
                              body1:
                                - lib: core.propsVars
                                  code: set
                                  values:
                                    var:
                                      lib: core.hidden
                                      code: variable
                                      values:
                                        variableName: pointX
                                    value:
                                      lib: core.math
                                      code: '*'
                                      values:
                                        a:
                                          lib: core.hidden
                                          code: property
                                          values:
                                            variableName: gridX
                                        b:
                                          lib: core.hidden
                                          code: global variable number
                                          values:
                                            variableName: mapCellWidth
                                - lib: core.propsVars
                                  code: set
                                  values:
                                    var:
                                      lib: core.hidden
                                      code: variable
                                      values:
                                        variableName: pointY
                                    value:
                                      lib: core.math
                                      code: '*'
                                      values:
                                        a:
                                          lib: core.hidden
                                          code: property
                                          values:
                                            variableName: gridY
                                        b:
                                          lib: core.hidden
                                          code: global variable number
                                          values:
                                            variableName: mapCellHeight
                                - lib: tween
                                  code: animate position
                                  values:
                                    then:
                                      - lib: core.propsVars
                                        code: set
                                        values:
                                          var:
                                            lib: core.hidden
                                            code: property
                                            values:
                                              variableName: animation
                                          value:
                                            lib: core.logic
                                            code: 'false'
                                            values: {}
                                    catch: []
                                    target:
                                      lib: core.propsVars
                                      code: this
                                      values: {}
                                    x:
                                      lib: core.hidden
                                      code: variable
                                      values:
                                        variableName: pointX
                                    'y':
                                      lib: core.hidden
                                      code: variable
                                      values:
                                        variableName: pointY
                                    curve:
                                      lib: tween
                                      code: tween.linear
                                      values: {}
                                    return:
                                      lib: core.hidden
                                      code: property
                                      values:
                                        variableName: animation
                                    ms:
                                      lib: core.math
                                      code: '*'
                                      values:
                                        b: 1000
                                        a:
                                          lib: core.hidden
                                          code: behavior property
                                          values:
                                            variableName: cellTime
                              condition:
                                lib: core.logic
                                code: a OR b
                                values:
                                  a:
                                    lib: core.logic
                                    code: is not
                                    values:
                                      a:
                                        lib: core.math
                                        code: '%'
                                        values:
                                          a:
                                            lib: core.movement
                                            code: x
                                            values: {}
                                          b:
                                            lib: core.hidden
                                            code: global variable number
                                            values:
                                              variableName: mapCellWidth
                                      b: 0
                                  b:
                                    lib: core.logic
                                    code: is not
                                    values:
                                      a:
                                        lib: core.math
                                        code: '%'
                                        values:
                                          a:
                                            lib: core.movement
                                            code: 'y'
                                            values: {}
                                          b:
                                            lib: core.hidden
                                            code: global variable number
                                            values:
                                              variableName: mapCellHeight
                                      b: 0
                        condition:
                          lib: core.misc
                          code: get function option
                          values:
                            key: adjustPosition
                  store:
                    lib: core.hidden
                    code: property
                    values:
                      variableName: abortPath
            arguments: {}
            lib: core
            variables:
              - nextX
              - nextY
              - pointX
              - pointY
              - movementCost
              - moveDuration
              - prevX
              - prevY
              - distance
              - targetCol
              - targetRow
        specification:
          - structure: atomic
            type: number
            mappedType: number
            name: cellTime
            readableName: 'Default cell traversal time, in sec.'
            required: false
            fixedLength: 0
          - structure: atomic
            type: checkbox
            mappedType: number
            name: ignoreCost
            readableName: Ignore movement cost
            required: false
            fixedLength: 0
          - structure: atomic
            type: script
            mappedType: number
            name: onCellChanged
            readableName: When stepping on a cell
            required: false
            fixedLength: 0
          - structure: atomic
            type: script
            mappedType: number
            name: onArrived
            readableName: When path finishes
            required: false
            fixedLength: 0
        extendTypes: ''
        lastmod: 1772440106485
        uid: D2RqLdcMm2P2Fb
        properties:
          - goToPoint
          - stepPath
          - abortPath
          - startPath
          - pointIndex
          - path
          - pathDebug
          - animation
          - gridX
          - gridY
          - pathID
      - type: behavior
        name: PathdindingInteractive
        behaviorType: template
        events:
          - eventKey: OnCreate
            code:
              - lib: core.misc
                code: note
                values:
                  note: >-
                    This behavior is for non-moving obstacles on the map that
                    can be dynamically added or removed, like doors and gates,
                    or destructible walls.
              - lib: core.misc
                code: note
                values:
                  note: >-
                    Copies' Creation events that were placed in a room manually
                    in the room editor run before the rooms' Room start event,
                    so if we ignore a point right away, it will be written to
                    the previous room's map, not the new one. To counter that,
                    we will put all obstacles put in a room in an array that the
                    room will later read.
              - lib: core.logic
                code: if else branch
                values:
                  body1:
                    - lib: core.arrays
                      code: array push
                      values:
                        elt:
                          lib: core.propsVars
                          code: this
                          values: {}
                        array:
                          lib: core.hidden
                          code: global variable raw
                          values:
                            variableName: interactive
                  body2:
                    - lib: core.arrays
                      code: array 2d set element
                      values:
                        array:
                          lib: core.hidden
                          code: global variable raw
                          values:
                            variableName: interactiveMap
                        column:
                          lib: core.math
                          code: round
                          values:
                            a:
                              lib: core.math
                              code: /
                              values:
                                a:
                                  lib: core.movement
                                  code: x
                                  values: {}
                                b:
                                  lib: core.hidden
                                  code: global variable number
                                  values:
                                    variableName: mapCellWidth
                        row:
                          lib: core.math
                          code: round
                          values:
                            a:
                              lib: core.math
                              code: /
                              values:
                                a:
                                  lib: core.movement
                                  code: 'y'
                                  values: {}
                                b:
                                  lib: core.hidden
                                  code: global variable number
                                  values:
                                    variableName: mapCellHeight
                        value:
                          lib: core.propsVars
                          code: this
                          values: {}
                  condition:
                    lib: core.templates
                    code: copy placedInRoom
                    values: {}
            arguments: {}
            lib: core
            variables: []
          - eventKey: OnDestroy
            code:
              - lib: core.arrays
                code: array 2d set element
                values:
                  array:
                    lib: core.hidden
                    code: global variable raw
                    values:
                      variableName: interactiveMap
                  column:
                    lib: core.math
                    code: round
                    values:
                      a:
                        lib: core.math
                        code: /
                        values:
                          a:
                            lib: core.movement
                            code: x
                            values: {}
                          b:
                            lib: core.hidden
                            code: global variable number
                            values:
                              variableName: mapCellWidth
                  row:
                    lib: core.math
                    code: round
                    values:
                      a:
                        lib: core.math
                        code: /
                        values:
                          a:
                            lib: core.movement
                            code: 'y'
                            values: {}
                          b:
                            lib: core.hidden
                            code: global variable number
                            values:
                              variableName: mapCellHeight
                  value:
                    lib: core.logic
                    code: 'false'
                    values: {}
            arguments: {}
            lib: core
            variables: []
        specification: []
        extendTypes: ''
        lastmod: 1772293788242
        uid: Md1r93tcT41J7H
        properties: []
      - uid: RcKptRM5nkWf6d
        name: SetupAdjacentCells
        code:
          - lib: core.misc
            code: note
            values:
              note: >-
                This script runs at the start of the game and prefills the
                adjacentCells array that is used by the character template to
                look around itself without bloating its code.
          - lib: core.arrays
            code: array create
            values:
              return:
                lib: core.hidden
                code: global variable raw
                values:
                  variableName: adjacentCells
          - lib: core.objects
            code: new object
            values:
              return:
                lib: core.hidden
                code: variable
                values:
                  variableName: point
            customOptions:
              x: '1'
              'y': '0'
          - lib: core.arrays
            code: array push
            values:
              elt:
                lib: core.hidden
                code: variable
                values:
                  variableName: point
              array:
                lib: core.hidden
                code: global variable raw
                values:
                  variableName: adjacentCells
          - lib: core.objects
            code: new object
            values:
              return:
                lib: core.hidden
                code: variable
                values:
                  variableName: point
            customOptions:
              x: '0'
              'y': '1'
          - lib: core.arrays
            code: array push
            values:
              elt:
                lib: core.hidden
                code: variable
                values:
                  variableName: point
              array:
                lib: core.hidden
                code: global variable raw
                values:
                  variableName: adjacentCells
          - lib: core.objects
            code: new object
            values:
              return:
                lib: core.hidden
                code: variable
                values:
                  variableName: point
            customOptions:
              x: '-1'
              'y': '0'
          - lib: core.arrays
            code: array push
            values:
              elt:
                lib: core.hidden
                code: variable
                values:
                  variableName: point
              array:
                lib: core.hidden
                code: global variable raw
                values:
                  variableName: adjacentCells
          - lib: core.objects
            code: new object
            values:
              return:
                lib: core.hidden
                code: variable
                values:
                  variableName: point
            customOptions:
              x: '0'
              'y': '-1'
          - lib: core.arrays
            code: array push
            values:
              elt:
                lib: core.hidden
                code: variable
                values:
                  variableName: point
              array:
                lib: core.hidden
                code: global variable raw
                values:
                  variableName: adjacentCells
        language: catnip
        variables:
          - point
        runAutomatically: true
